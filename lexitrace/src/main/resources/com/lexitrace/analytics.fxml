<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.*?>

<!--
    analytics.fxml — LexiTrace Analytics Screen
    fx:controller wired to AnalyticsController.java
    fx:ids used: masteryBarChart, correctnessPieChart,
                 totalStudiedLabel
    Designer: Mridul (UI Lead)
-->
<BorderPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.lexitrace.controller.AnalyticsController"
    styleClass="screen-root"
    stylesheets="@styles.css"
    prefWidth="960" prefHeight="660">

    <!-- ════════════════════════════════════════════════════
         TOP — Navigation Bar
    ════════════════════════════════════════════════════ -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="2">
                <Label text="Lexi" styleClass="navbar-brand"/>
                <Label text="Trace" styleClass="navbar-brand-accent"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="4">
                <padding><Insets right="16"/></padding>
                <Button text="⚡  Quiz"      styleClass="btn-ghost" onAction="#goToQuiz"/>
                <Button text="📖  Vocabulary" styleClass="btn-ghost" onAction="#goToVocab"/>
                <Button text="🏠  Dashboard"  styleClass="btn-ghost" onAction="#goToDashboard"/>
            </HBox>
            <Button text="Sign Out" styleClass="btn-logout" onAction="#onLogout"/>
        </HBox>
    </top>

    <!-- ════════════════════════════════════════════════════
         CENTER — Analytics Body
    ════════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #0d0f14; -fx-background: #0d0f14;">
            <VBox spacing="28" style="-fx-background-color: #0d0f14;">
                <padding><Insets top="36" right="48" bottom="48" left="48"/></padding>

                <!-- Page header -->
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="ANALYTICS" styleClass="label-tag"/>
                        <Label text="Learning Progress"
                               style="-fx-font-family: 'Outfit','Segoe UI',sans-serif;
                                      -fx-font-size: 26px; -fx-font-weight: 700;
                                      -fx-text-fill: #e8ecf4;"/>
                    </VBox>

                    <!-- Total studied stat badge -->
                    <VBox styleClass="stat-card" alignment="CENTER" spacing="4"
                          prefWidth="140">
                        <Label text="TOTAL STUDIED" styleClass="label-tag"/>
                        <Label fx:id="totalStudiedLabel"
                               text="—"
                               style="-fx-font-family: 'Outfit','Segoe UI',sans-serif;
                                      -fx-font-size: 30px; -fx-font-weight: 800;
                                      -fx-text-fill: #4f9cf9;"/>
                        <Label text="words" styleClass="muted-text"/>
                    </VBox>
                </HBox>

                <!-- Accent line -->
                <Region styleClass="accent-line" prefHeight="1.5" maxWidth="Infinity"
                        style="-fx-opacity: 0.5;"/>

                <!-- ── Charts Row ──────────────────────── -->
                <HBox spacing="20" fillHeight="true">

                    <!-- Bar Chart — Mastery Distribution -->
                    <VBox styleClass="card" spacing="12" HBox.hgrow="ALWAYS">

                        <Label text="MASTERY DISTRIBUTION" styleClass="label-tag"/>
                        <Label text="Words by mastery level"
                               style="-fx-font-family: 'Outfit','Segoe UI',sans-serif;
                                      -fx-font-size: 15px; -fx-font-weight: 600;
                                      -fx-text-fill: #e8ecf4;"/>

                        <BarChart fx:id="masteryBarChart"
                                  VBox.vgrow="ALWAYS"
                                  prefHeight="280"
                                  animated="true"
                                  legendVisible="false"
                                  style="-fx-background-color: transparent;">
                            <xAxis>
                                <CategoryAxis label="" tickLabelFill="#6b7494"
                                              style="-fx-tick-label-fill: #6b7494;"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Words" minorTickVisible="false"
                                            style="-fx-tick-label-fill: #6b7494;"/>
                            </yAxis>
                        </BarChart>

                    </VBox>

                    <!-- Pie Chart — Correct vs Incorrect -->
                    <VBox styleClass="card" spacing="12" prefWidth="300"
                          minWidth="280">

                        <Label text="ANSWER ACCURACY" styleClass="label-tag"/>
                        <Label text="Correct vs Incorrect"
                               style="-fx-font-family: 'Outfit','Segoe UI',sans-serif;
                                      -fx-font-size: 15px; -fx-font-weight: 600;
                                      -fx-text-fill: #e8ecf4;"/>

                        <PieChart fx:id="correctnessPieChart"
                                  VBox.vgrow="ALWAYS"
                                  prefHeight="260"
                                  animated="true"
                                  clockwise="true"
                                  startAngle="90"
                                  style="-fx-background-color: transparent;"/>

                    </VBox>

                </HBox><!-- /charts row -->

                <!-- ── Mastery level legend ─────────────── -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="MASTERY LEVELS :" styleClass="label-tag"/>
                    <Label text="New"       styleClass="mastery-badge mastery-new"/>
                    <Label text="Learning"  styleClass="mastery-badge mastery-learning"/>
                    <Label text="Familiar"  styleClass="mastery-badge mastery-familiar"/>
                    <Label text="Mastered"  styleClass="mastery-badge mastery-mastered"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
