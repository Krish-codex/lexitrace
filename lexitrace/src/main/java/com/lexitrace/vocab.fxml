<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
    vocab.fxml — LexiTrace Vocabulary Screen
    fx:controller wired to VocabController.java
    fx:ids used: vocabTable, colWord, colTranslation,
                 colPOS, colPair
    Designer: Mridul (UI Lead)
-->
<BorderPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.lexitrace.controller.VocabController"
    styleClass="screen-root"
    stylesheets="@styles.css"
    prefWidth="960" prefHeight="660">

    <!-- ════════════════════════════════════════════════════
         TOP — Navigation Bar
    ════════════════════════════════════════════════════ -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="2">
                <Label text="Lexi" styleClass="navbar-brand"/>
                <Label text="Trace" styleClass="navbar-brand-accent"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="4">
                <padding><Insets right="16"/></padding>
                <Button text="⚡  Quiz"    styleClass="btn-ghost" onAction="#goToQuiz"/>
                <Button text="📊  Analytics" styleClass="btn-ghost" onAction="#goToAnalytics"/>
                <Button text="🏠  Dashboard" styleClass="btn-ghost" onAction="#goToDashboard"/>
            </HBox>
            <Button text="Sign Out" styleClass="btn-logout" onAction="#onLogout"/>
        </HBox>
    </top>

    <!-- ════════════════════════════════════════════════════
         CENTER — Vocabulary Body
    ════════════════════════════════════════════════════ -->
    <center>
        <VBox spacing="24" style="-fx-background-color: #0d0f14;">
            <padding><Insets top="36" right="48" bottom="48" left="48"/></padding>

            <!-- Page header -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="VOCABULARY" styleClass="label-tag"/>
                    <Label text="Word List"
                           style="-fx-font-family: 'Outfit','Segoe UI',sans-serif;
                                  -fx-font-size: 26px; -fx-font-weight: 700;
                                  -fx-text-fill: #e8ecf4;"/>
                </VBox>
            </HBox>

            <!-- Accent line -->
            <Region styleClass="accent-line" prefHeight="1.5" maxWidth="Infinity"
                    style="-fx-opacity: 0.5;"/>

            <!-- Toolbar: search + filter -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <!-- Search field -->
                <TextField styleClass="search-field"
                           promptText="🔍  Search words…"
                           prefWidth="280"/>

                <!-- Language pair filter -->
                <ComboBox styleClass="combo-box"
                          promptText="All pairs"
                          prefWidth="160">
                    <items>
                        <javafx.collections.FXCollections fx:factory="observableArrayList">
                            <String fx:value="All pairs"/>
                            <String fx:value="en → de"/>
                            <String fx:value="en → fr"/>
                            <String fx:value="en → es"/>
                        </javafx.collections.FXCollections>
                    </items>
                </ComboBox>

                <!-- Spacer -->
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Row count label -->
                <Label text="0 words"
                       styleClass="muted-text"
                       style="-fx-font-size: 12px;"/>

            </HBox>

            <!-- ── Table ───────────────────────────────── -->
            <TableView fx:id="vocabTable"
                       VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #161922;">

                <columns>

                    <!-- Word -->
                    <TableColumn fx:id="colWord"
                                 text="WORD"
                                 prefWidth="200"
                                 style="-fx-font-family: 'Outfit','Segoe UI',sans-serif;
                                        -fx-font-size: 11px; -fx-font-weight: 600;"/>

                    <!-- Translation -->
                    <TableColumn fx:id="colTranslation"
                                 text="TRANSLATION"
                                 prefWidth="200"/>

                    <!-- Part of Speech -->
                    <TableColumn fx:id="colPOS"
                                 text="PART OF SPEECH"
                                 prefWidth="160"/>

                    <!-- Language Pair -->
                    <TableColumn fx:id="colPair"
                                 text="PAIR"
                                 prefWidth="100"/>

                    <!-- Mastery Level -->
                    <TableColumn fx:id="colMastery"
                                 text="MASTERY"
                                 prefWidth="130"/>

                </columns>

                <placeholder>
                    <VBox alignment="CENTER" spacing="12"
                          style="-fx-background-color: transparent;">
                        <Label text="📭"
                               style="-fx-font-size: 36px;"/>
                        <Label text="No words found"
                               style="-fx-font-family: 'Outfit','Segoe UI',sans-serif;
                                      -fx-font-size: 15px; -fx-font-weight: 600;
                                      -fx-text-fill: #e8ecf4;"/>
                        <Label text="Your vocabulary list will appear here"
                               styleClass="muted-text"/>
                    </VBox>
                </placeholder>

            </TableView>

        </VBox>
    </center>

</BorderPane>
