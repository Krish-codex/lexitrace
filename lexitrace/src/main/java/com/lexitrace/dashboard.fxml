<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
    dashboard.fxml — LexiTrace Dashboard Screen
    fx:controller wired to DashboardController.java
    fx:ids used: welcomeLabel, masteredLabel, correctLabel,
                 incorrectLabel, studiedLabel
    Designer: Mridul (UI Lead)
-->
<BorderPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.lexitrace.controller.DashboardController"
    styleClass="screen-root"
    stylesheets="@styles.css"
    prefWidth="960" prefHeight="660">

    <!-- ════════════════════════════════════════════════════
         TOP — Navigation Bar
    ════════════════════════════════════════════════════ -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="0">

            <!-- Brand -->
            <HBox alignment="CENTER_LEFT" spacing="2">
                <Label text="Lexi" styleClass="navbar-brand"/>
                <Label text="Trace" styleClass="navbar-brand-accent"/>
            </HBox>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Nav buttons -->
            <HBox alignment="CENTER" spacing="4">
                <padding><Insets right="16"/></padding>
                <Button text="⚡  Quiz"
                        styleClass="btn-ghost"
                        onAction="#goToQuiz"/>
                <Button text="📖  Vocabulary"
                        styleClass="btn-ghost"
                        onAction="#goToVocab"/>
                <Button text="📊  Analytics"
                        styleClass="btn-ghost"
                        onAction="#goToAnalytics"/>
            </HBox>

            <!-- Logout -->
            <Button text="Sign Out"
                    styleClass="btn-logout"
                    onAction="#onLogout"/>

        </HBox>
    </top>

    <!-- ════════════════════════════════════════════════════
         CENTER — Dashboard Body
    ════════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="screen-root"
                    style="-fx-background-color: #0d0f14;
                           -fx-background: #0d0f14;">
            <VBox spacing="32" style="-fx-background-color: #0d0f14;">
                <padding><Insets top="40" right="48" bottom="48" left="48"/></padding>

                <!-- ── Hero section ─────────────────────── -->
                <VBox spacing="6">
                    <Label text="Good to see you back,"
                           styleClass="muted-text"
                           style="-fx-font-size: 14px;"/>
                    <Label fx:id="welcomeLabel"
                           text="Learner 👋"
                           styleClass="screen-heading"
                           style="-fx-font-size: 30px;"/>
                    <Region styleClass="accent-line" prefHeight="2"
                            maxWidth="260"
                            style="-fx-opacity: 0.7;">
                        <VBox.margin><Insets top="6"/></VBox.margin>
                    </Region>
                </VBox>

                <!-- ── Stats Row ─────────────────────────── -->
                <HBox spacing="16" fillHeight="true">

                    <!-- Words Mastered -->
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS"
                          alignment="TOP_LEFT">
                        <Label text="MASTERED"
                               styleClass="label-tag"/>
                        <Label fx:id="masteredLabel"
                               text="—"
                               style="-fx-font-family: 'Outfit', 'Segoe UI', sans-serif;
                                      -fx-font-size: 36px; -fx-font-weight: 800;
                                      -fx-text-fill: #34d399;"/>
                        <Label text="words learned"
                               styleClass="muted-text"/>
                    </VBox>

                    <!-- Correct Answers -->
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS"
                          alignment="TOP_LEFT">
                        <Label text="CORRECT" styleClass="label-tag"/>
                        <Label fx:id="correctLabel"
                               text="—"
                               style="-fx-font-family: 'Outfit', 'Segoe UI', sans-serif;
                                      -fx-font-size: 36px; -fx-font-weight: 800;
                                      -fx-text-fill: #4f9cf9;"/>
                        <Label text="correct answers" styleClass="muted-text"/>
                    </VBox>

                    <!-- Incorrect Answers -->
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS"
                          alignment="TOP_LEFT">
                        <Label text="INCORRECT" styleClass="label-tag"/>
                        <Label fx:id="incorrectLabel"
                               text="—"
                               style="-fx-font-family: 'Outfit', 'Segoe UI', sans-serif;
                                      -fx-font-size: 36px; -fx-font-weight: 800;
                                      -fx-text-fill: #f87171;"/>
                        <Label text="incorrect answers" styleClass="muted-text"/>
                    </VBox>

                    <!-- Words Studied -->
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS"
                          alignment="TOP_LEFT">
                        <Label text="STUDIED" styleClass="label-tag"/>
                        <Label fx:id="studiedLabel"
                               text="—"
                               style="-fx-font-family: 'Outfit', 'Segoe UI', sans-serif;
                                      -fx-font-size: 36px; -fx-font-weight: 800;
                                      -fx-text-fill: #a78bfa;"/>
                        <Label text="words studied" styleClass="muted-text"/>
                    </VBox>

                </HBox><!-- /stats row -->

                <!-- ── Quick actions ─────────────────────── -->
                <VBox spacing="14">
                    <Label text="QUICK ACTIONS" styleClass="label-tag"/>

                    <HBox spacing="16">

                        <!-- Start Quiz card -->
                        <VBox styleClass="card" spacing="12"
                              HBox.hgrow="ALWAYS" alignment="TOP_LEFT"
                              style="-fx-cursor: hand;"
                              onMouseClicked="#goToQuiz">
                            <Label text="⚡"
                                   style="-fx-font-size: 28px;"/>
                            <VBox spacing="4">
                                <Label text="Start Quiz"
                                       style="-fx-font-family: 'Outfit','Segoe UI',sans-serif;
                                              -fx-font-size: 16px; -fx-font-weight: 700;
                                              -fx-text-fill: #e8ecf4;"/>
                                <Label text="Practice words due for review"
                                       styleClass="muted-text"/>
                            </VBox>
                            <Button text="Start →"
                                    styleClass="btn-primary"
                                    onAction="#goToQuiz"
                                    style="-fx-padding: 8 20;"/>
                        </VBox>

                        <!-- Vocabulary card -->
                        <VBox styleClass="card" spacing="12"
                              HBox.hgrow="ALWAYS" alignment="TOP_LEFT"
                              style="-fx-cursor: hand;"
                              onMouseClicked="#goToVocab">
                            <Label text="📖"
                                   style="-fx-font-size: 28px;"/>
                            <VBox spacing="4">
                                <Label text="Vocabulary"
                                       style="-fx-font-family: 'Outfit','Segoe UI',sans-serif;
                                              -fx-font-size: 16px; -fx-font-weight: 700;
                                              -fx-text-fill: #e8ecf4;"/>
                                <Label text="Browse and manage word list"
                                       styleClass="muted-text"/>
                            </VBox>
                            <Button text="Browse →"
                                    styleClass="btn-secondary"
                                    onAction="#goToVocab"
                                    style="-fx-padding: 8 20;"/>
                        </VBox>

                        <!-- Analytics card -->
                        <VBox styleClass="card" spacing="12"
                              HBox.hgrow="ALWAYS" alignment="TOP_LEFT"
                              style="-fx-cursor: hand;"
                              onMouseClicked="#goToAnalytics">
                            <Label text="📊"
                                   style="-fx-font-size: 28px;"/>
                            <VBox spacing="4">
                                <Label text="Analytics"
                                       style="-fx-font-family: 'Outfit','Segoe UI',sans-serif;
                                              -fx-font-size: 16px; -fx-font-weight: 700;
                                              -fx-text-fill: #e8ecf4;"/>
                                <Label text="Track your learning progress"
                                       styleClass="muted-text"/>
                            </VBox>
                            <Button text="View →"
                                    styleClass="btn-secondary"
                                    onAction="#goToAnalytics"
                                    style="-fx-padding: 8 20;"/>
                        </VBox>

                    </HBox>

                </VBox><!-- /quick actions -->

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
